# Copy to `.env.local` for local development (not committed).

# Canonical site URL (no trailing slash). On Vercel you can omit this — VERCEL_URL is used automatically.
# NEXT_PUBLIC_SITE_URL=https://trivion-protection.vercel.app

# Optional: override the built-in n8n webhook URL used by POST /api/contact
# LEADMAKER_WEBHOOK_URL=https://hooks.leadmaker.agency/webhook/your-other-id
