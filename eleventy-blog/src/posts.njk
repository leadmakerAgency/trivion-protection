---
layout: layouts/base.njk
title: Posts
permalink: /posts/index.html
---
<h1>Posts</h1>
<ul class="post-list">
  {% for post in collections.posts | reverse %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      {% if post.data.date %}<span class="post-list-date">{{ post.data.date }}</span>{% endif %}
    </li>
  {% endfor %}
</ul>
